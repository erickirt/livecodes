{
  "name": "storybook",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "postinstall": "run-p install:*",
    "install:preact": "cd preact && npm ci --force",
    "install:react": "cd react && npm ci",
    "install:solid": "cd solid && npm ci",
    "install:svelte": "cd svelte && npm ci",
    "install:vue": "cd vue && npm ci",
    "install:web-components": "cd web-components && npm ci --force",
    "format-stories": "run-p format-stories:*",
    "format-stories:preact": "prettier preact/stories --write",
    "format-stories:react": "prettier react/stories --write",
    "format-stories:solid": "prettier solid/stories --write",
    "format-stories:svelte": "prettier svelte/stories --write",
    "format-stories:vue": "prettier vue/stories --write",
    "format-stories:web-components": "prettier web-components/stories --write",
    "build": "run-p build:* && node ./scripts/copy-index.mjs",
    "build:preact": "cd preact && npm run build-storybook -- -o ../../build/stories/preact",
    "build:react": "cd react && npm run build-storybook -- -o ../../build/stories/react",
    "build:solid": "cd solid && npm run build-storybook -- -o ../../build/stories/solid",
    "build:svelte": "cd svelte && npm run build-storybook -- -o ../../build/stories/svelte",
    "build:vue": "cd vue && npm run build-storybook -- -o ../../build/stories/vue",
    "build:web-components": "cd web-components && npm run build-storybook -- -o ../../build/stories/web-components",
    "typecheck": "run-p typecheck:*",
    "typecheck:root": "tsc --noEmit",
    "typecheck:preact": "cd preact && npx tsc --noEmit",
    "typecheck:react": "cd react && npx tsc --noEmit",
    "typecheck:solid": "cd solid && npx tsc --noEmit",
    "typecheck:svelte": "cd svelte && npx tsc --noEmit",
    "typecheck:vue": "cd vue && npx tsc --noEmit",
    "typecheck:web-components": "cd web-components && npx tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "type": "module",
  "dependencies": {
    "@storybook/addon-docs": "10.3.1",
    "@storybook/react-vite": "10.3.1",
    "dedent": "1.7.2",
    "flat": "6.0.1",
    "livecodes": "../build/sdk"
  },
  "devDependencies": {
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "typescript": "^5.9.3"
  }
}
